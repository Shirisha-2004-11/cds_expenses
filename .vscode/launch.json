{
    "version": "0.2.0",
    "configurations": [

        // ── Web (Chrome) — always on port 4200 for Microsoft SSO ───────
        {
            "name": "cds_expenses (Chrome)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "args": ["--web-port", "4200"]
        },
        {
            "name": "cds_expenses (Chrome - profile mode)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "flutterMode": "profile",
            "args": ["--web-port", "4200"]
        },
        {
            "name": "cds_expenses (Chrome - release mode)",
            "request": "launch",
            "type": "dart",
            "deviceId": "chrome",
            "flutterMode": "release",
            "args": ["--web-port", "4200"]
        },

        // ── Android ────────────────────────────────────────────────────
        {
            "name": "cds_expenses (Android)",
