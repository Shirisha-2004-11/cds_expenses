        },
        {
            "name": "cds_expenses (Android - profile mode)",
            "request": "launch",
            "type": "dart",
            "deviceId": "android",
            "flutterMode": "profile"
        },
        {
            "name": "cds_expenses (Android - release mode)",
            "request": "launch",
            "type": "dart",
            "deviceId": "android",
            "flutterMode": "release"
        },

        // ── iOS ────────────────────────────────────────────────────────
        {
